#!name=⚡ Nguyễn Ngọc Anh Tú 🌸 - Premium (Ultimate)
#!desc=✨ 20+ Apps Premium: Locket Gold + 车票票 + YouTube + Spotify + SoundCloud + PicsArt + Lightroom + Photoshop + Emby + KineMaster + Calm + Headspace + AlightMotion + Wink + Truecaller + CamScanner + BeautyPlus + VSCO + Snow + Meitu + Sub-Store
#!version=8.0.0
#!date=2026-05-09
#!author=Nguyễn Ngọc Anh Tú (PremiumCC)
#!homepage=https://github.com/intekaih/PremiumCC
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Unlock.png

[Rule]
# === BLOCK QUIC FOR YOUTUBE MITM ===
AND,((DOMAIN-SUFFIX,googlevideo.com), (PROTOCOL,UDP)),REJECT
AND,((DOMAIN,youtubei.googleapis.com), (PROTOCOL,UDP)),REJECT

# === SPOTIFY ADS ===
DOMAIN-SUFFIX,audio-ak-spotify-com.akamaized.net,REJECT
DOMAIN-SUFFIX,audio4-ak-spotify-com.akamaized.net,REJECT
DOMAIN-SUFFIX,heads-ak-spotify-com.akamaized.net,REJECT
DOMAIN-SUFFIX,heads4-ak-spotify-com.akamaized.net,REJECT
DOMAIN,spclient.wg.spotify.com,DIRECT
DOMAIN-KEYWORD,spotify-ads,REJECT



[Header Rewrite]
# === REVENUECAT REMOVE ETAG ===
^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/?(.*?)*$) header-del x-revenuecat-etag
^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/?(.*?)*$) header-del X-RevenueCat-ETag

# === SPOTIFY REMOVE CACHE HEADERS ===
^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/user-customization-service\/v1\/customize$ header-del if-none-match

[URL Rewrite]
# === YOUTUBE - Block ads and tracking ===
^https?:\/\/[\w-]+\.googlevideo\.com\/(?!(dclk_video_ads|videoplayback\?)).+&oad _ reject-200
^https?:\/\/(www|s)\.youtube\.com\/api\/stats\/ads _ reject-200
^https?:\/\/(www|s)\.youtube\.com\/(pagead|ptracking) _ reject-200
^https?:\/\/s\.youtube\.com\/api\/stats\/qoe\?adcontext _ reject-200
(^https?:\/\/[\w-]+\.googlevideo\.com\/(?!dclk_video_ads).+?)&ctier=L(&.+?),ctier,(.+) $1$2$3 302

# === REVENUECAT (Moved to Header Rewrite) ===
^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^\/]+$) header-remove X-RevenueCat-ETag 302
^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^\/]+$) header-remove x-revenuecat-etag 302

# === SPOTIFY (Moved to Header Rewrite) ===
^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(user-customization-service\/v1\/customize|bootstrap\/v1\/bootstrap)$ header-remove if-none-match 302

[Map Local]
# === YOUTUBE - Block initplayback ads ===
^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad data-type=text data="" status-code=200

[MITM]
enable = true
hostname = *.googlevideo.com, youtubei.googleapis.com, www.youtube.com, s.youtube.com, -redirector*.googlevideo.com, spclient.wg.spotify.com, *-spclient.spotify.com, api.revenuecat.com, api.rc-backup.com, buy.itunes.apple.com, api.picsart.c*, api.meiease.c*, api-mobile.soundcloud.com, mb3admin.com, api-account.kinemasters.com, photos.adobe.io, lcs-mobile-cops.adobe.io, api.calm.com, api.prod.headspace.com, us-central1-alight-creative.cloudfunctions.net, api-sub.meitu.com, premium*.truecaller.com, ap*.intsig.net, api.mr.pixocial.com, newbeee-api.beautyplus.com, user-snow-api.snow.me, h5.xiuxiu.meitu.com, api.xiuxiu.meitu.com, sub.store

[Script]
# === YOUTUBE PREMIUM - ekaznyra Version (2026-05-09) ===
# Blocks all ads + enables background playback + PiP
youtube.request = type=http-request, pattern=^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(browse|next|player|reel\/reel_watch_sequence|get_watch), requires-body=1, max-size=-1, binary-body-mode=1, engine=jsc, script-path=https://raw.githubusercontent.com/ekaznyra/PremiumCC/refs/heads/main/Module/js/youtube.response.js

youtube.response = type=http-response, pattern=^https:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch), requires-body=1, max-size=-1, binary-body-mode=1, script-path=https://raw.githubusercontent.com/ekaznyra/PremiumCC/refs/heads/main/Module/js/youtube.response.js, argument="{"lyricLang":"vi","captionLang":"vi","blockUpload":false,"blockImmersive":false,"debug":false}"

# === SPOTIFY PREMIUM - PremiumCC (Updated 2026-05-09) ===
spotify-json = type=http-request, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(artistview\/v1\/artist|album-entity-view\/v2\/album)\/, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/spotify-json.js, requires-body=false, timeout=10, max-size=131072
spotify-proto = type=http-response, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/spotify-proto.js, requires-body=true, timeout=10, max-size=131072

# === SOUNDCLOUD GO+ - PremiumCC (2026-04-21) ===
soundcloud-response = type=http-response, pattern=^https://api-mobile\.soundcloud\.com/configuration/ios$, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/SoundCloudGoPlus.js, requires-body=true, timeout=15

# === PICSART GOLD - PremiumCC (2026-04-21) ===
picsart-response = type=http-response, pattern=^https:\/\/api\.picsart\.com\/gw-v2\/shop\/subscription\/apple\/purchases, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/PicsArt.js, requires-body=true, max-size=0, timeout=60
picsart-storages = type=http-response, pattern=^https:\/\/api\.picsart\.com\/gw-v2\/cloud-storage\/v1\/me\/storages, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/PicsArt.js, requires-body=true, max-size=0, timeout=60

# === LIGHTROOM PREMIUM - PremiumCC (2026-05-09) ===
lightroom-response = type=http-response, pattern=^https:\/\/photos\.adobe\.io\/v2\/accounts, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/lightroom.js, requires-body=true, timeout=10, max-size=131072

# === PHOTOSHOP EXPRESS PREMIUM - PremiumCC (2026-05-09) ===
photoshop-response = type=http-response, pattern=^https:\/\/lcs-mobile-cops\.adobe\.io\/mobile_profile, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/photoshop.js, requires-body=true, timeout=10, max-size=131072

# === EMBY PREMIERE - PremiumCC (2026-05-09) ===
emby-response = type=http-response, pattern=^https?://mb3admin\.com/admin/service/registration/validateDevice, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/emby.js, requires-body=true, timeout=10

# === KINEMASTER PRO - PremiumCC (2026-04-21) ===
kinemaster-response = type=http-response, pattern=^https://api-account\.kinemasters\.com/v\d/user/subscribe$, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/Kinemaster.js, requires-body=true, timeout=10

# === CALM PREMIUM - PremiumCC (2026-05-09) ===
calm-response = type=http-response, pattern=^https:\/\/api\.calm\.com\/me$, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/calm.js, requires-body=true, timeout=10, max-size=131072

# === HEADSPACE PREMIUM - PremiumCC (2026-05-09) ===
headspace-response = type=http-response, pattern=^https:\/\/api\.prod\.headspace\.com\/.*\/user-subscriptions, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/headspace.js, requires-body=true, timeout=10, max-size=131072

# === ALIGHT MOTION PRO - PremiumCC (2026-04-21) ===
alightmotion-response = type=http-response, pattern=^https://us-central1-alight-creative\.cloudfunctions\.net/getAccountStatusAndLicenses, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/AlightMotion.js, requires-body=true, timeout=10

# === WINK VIP - PremiumCC (2026-04-21) ===
wink-response = type=http-response, pattern=^https?://api-sub\.meitu\.com/v2/user/vip_info_by_group\.json, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/WinkVipCrack.js, requires-body=true, timeout=10

# === TRUECALLER PREMIUM - PremiumCC (2026-04-21) ===
truecaller-response = type=http-response, pattern=^https:\/\/premium-(.+)\.truecaller\.com\/v\d\/(subscriptions|products\/apple), script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/TrueCaller.js, requires-body=true, timeout=10

# === CAMSCANNER PREMIUM - PremiumCC (2026-04-21) ===
camscanner-response = type=http-response, pattern=^https:\/\/(api|api-cs.*)\.intsig\.net\/(purchase\/cs\/query_prop|queryProperty|getPrivilegeItem), script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/camScanner.js, requires-body=true, timeout=15

# === BEAUTYPLUS PREMIUM - PremiumCC (2026-04-21) ===
beautyplus-response = type=http-response, pattern=^https:\/\/(api\.mr\.pixocial\.com\/v1\/manual_unlock|newbeee-api\.beautyplus\.com\/api\/v1\/asset\/balance), script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/BeautyPlus.js, requires-body=true, timeout=60, max-size=0

# === REVENUECAT MULTI-APP (Locket Gold + 车票票) - PremiumCC (2026-04-21) ===
revenuecat-response = type=http-response, pattern=^https:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^\/]+$), script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/revenuecat_multi.js, requires-body=true, timeout=60, max-size=131072
revenuecat-header = type=http-request, pattern=^https:\/\/api\.revenuecat\.com\/.+\/(receipts|subscribers), script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/deleteHeader.js, timeout=60

# === VSCO PREMIUM - PremiumCC (2026-05-09) ===
vsco-response = type=http-response, pattern=^https:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^\/]+$), script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/revenuecat_multi.js, requires-body=true, max-size=-1, timeout=60

# === REVENUECAT VIP (Generic Apps) - PremiumCC (2026-05-09) ===
revenuecat-vip = type=http-response, pattern=^https:\/\/api\.(revenuecat|rc-backup)\.com\/.+\/(receipts$|subscribers\/[^\/]+$), script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/revenuecat_multi.js, requires-body=true, max-size=-1, timeout=60

# === ITUNES PREMIUM - chxm1023 (2026-05-09) ===
itunes-response = type=http-response, pattern=^https?:\/\/buy\.itunes\.apple\.com\/verifyReceipt$, script-path=https://raw.githubusercontent.com/chxm1023/Rewrite/main/iTunes.js, requires-body=true, max-size=-1, timeout=60

# === SNOW PREMIUM - PremiumCC (2026-05-09) ===
snow-response = type=http-response, pattern=^https?:\/\/user-snow-api\.snow\.me\/v\d\/purchase\/subscription\/subscriber\/status, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/Snow.js, requires-body=true, max-size=-1, timeout=60

# === MEITU XIUXIU PREMIUM - PremiumCC (2026-05-09) ===
meitu-response = type=http-response, pattern=^https?:\/\/(h5|api)\.xiuxiu\.meitu\.com\/v\d\/(h\d\/vip|vip|user)\/, script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/MeiTuXiuXiu.js, requires-body=true, timeout=60

# === SUB-STORE (Node Management) ===
sub-store-core = type=http-request, pattern=^https?:\/\/sub\.store\/((download)|api\/(preview|sync|(utils\/node-info))), script-path=https://github.com/sub-store-org/Sub-Store/releases/latest/download/sub-store-1.min.js, requires-body=true, timeout=120
sub-store-simple = type=http-request, pattern=^https?:\/\/sub\.store, script-path=https://github.com/sub-store-org/Sub-Store/releases/latest/download/sub-store-0.min.js, requires-body=true, timeout=10
sub-store-sync = type=cron, cronexp=0 0 * * *, wake-system=1, timeout=120, script-path=https://github.com/sub-store-org/Sub-Store/releases/latest/download/cron-sync-artifacts.min.js
