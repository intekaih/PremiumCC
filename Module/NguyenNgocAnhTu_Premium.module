#!name=⚡ Nguyễn Ngọc Anh Tú 🌸 - Premium (Ultimate)
#!desc=✨ 17 Apps Premium: Locket Gold + 车票票 + YouTube + Spotify + SoundCloud + PicsArt + Lightroom + Photoshop + Emby + KineMaster + Calm + Headspace + AlightMotion + Wink + Truecaller + CamScanner + BeautyPlus + Sub-Store
#!version=7.2.1
#!date=2026-05-09
#!author=Nguyễn Ngọc Anh Tú (z3rokaze)
#!homepage=https://github.com/z3rokaze/NguyenNgocAnhTu
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Unlock.png

[Rule]
# === BLOCK QUIC FOR YOUTUBE MITM ===
AND,((DOMAIN-SUFFIX,googlevideo.com), (PROTOCOL,UDP)),REJECT
AND,((DOMAIN,youtubei.googleapis.com), (PROTOCOL,UDP)),REJECT

# === SPOTIFY ADS ===
DOMAIN-SUFFIX,audio-ak-spotify-com.akamaized.net,REJECT
DOMAIN-SUFFIX,audio4-ak-spotify-com.akamaized.net,REJECT
DOMAIN-SUFFIX,heads-ak-spotify-com.akamaized.net,REJECT
DOMAIN-SUFFIX,heads4-ak-spotify-com.akamaized.net,REJECT
DOMAIN,spclient.wg.spotify.com,DIRECT
DOMAIN-KEYWORD,spotify-ads,REJECT



[URL Rewrite]
# === YOUTUBE MAP LOCAL - Block initplayback ads ===
^https?:\/\/[\w-]+\.googlevideo\.com\/initplayback.+&oad data-type=text data="" status-code=200

# === REVENUECAT REMOVE ETAG ===
^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^\/]+$) header-remove X-RevenueCat-ETag 302
^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^\/]+$) header-remove x-revenuecat-etag 302

# === SPOTIFY REMOVE CACHE HEADERS ===
^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(user-customization-service\/v1\/customize|bootstrap\/v1\/bootstrap)$ header-remove if-none-match 302

[MITM]
enable = true
hostname = spclient.wg.spotify.com, *-spclient.spotify.com, api.revenuecat.com, api.picsart.c*, api.meiease.c*, api-mobile.soundcloud.com, mb3admin.com, api-account.kinemasters.com, photos.adobe.io, lcs-mobile-cops.adobe.io, api.calm.com, api.prod.headspace.com, us-central1-alight-creative.cloudfunctions.net, api-sub.meitu.com, premium*.truecaller.com, ap*.intsig.net, api.mr.pixocial.com, newbeee-api.beautyplus.com, sub.store, *.googlevideo.com, youtubei.googleapis.com

[Script]
# === YOUTUBE PREMIUM - Maasea Official (Verified Working 2025-07-12) ===
# Tested and confirmed working - Official stable version
youtube.response = type=http-response, pattern=^https:\/\/youtubei\.googleapis\.com\/(youtubei\/v1\/(browse|next|player|search|reel\/reel_watch_sequence|guide|account\/get_setting|get_watch))(\?(.*))?$, requires-body=1, max-size=-1, binary-body-mode=1, script-path=https://raw.githubusercontent.com/Maasea/sgmodule/master/Script/Youtube/youtube.response.js, argument="{"lyricLang":"off","captionLang":"off","blockUpload":true,"blockImmersive":true,"blockShorts":false,"debug":false}"

# === SPOTIFY PREMIUM - app2smile (Updated 2025.06.20) ===
spotify-json = type=http-request, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(artistview\/v1\/artist|album-entity-view\/v2\/album)\/, script-path=https://raw.githubusercontent.com/app2smile/rules/master/js/spotify-json.js, requires-body=false, timeout=10, max-size=131072
spotify-proto = type=http-response, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$, script-path=https://raw.githubusercontent.com/app2smile/rules/master/js/spotify-proto.js, requires-body=true, timeout=10, max-size=131072

# === SOUNDCLOUD GO+ - z3rokaze (2026-04-21) ===
soundcloud-response = type=http-response, pattern=^https://api-mobile\.soundcloud\.com/configuration/ios$, script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/SoundCloudGoPlus.js, requires-body=true, timeout=15

# === PICSART GOLD - NobyDa (2025) ===
picsart-response = type=http-response, pattern=^https://api\.(picsart|meiease)\.c(n|om)\/shop/subscription\/(validate|apple\/purchases), script-path=https://raw.githubusercontent.com/NobyDa/Script/master/Surge/JS/PicsArt.js, requires-body=true, max-size=0, timeout=30

# === LIGHTROOM PREMIUM - iSteal-it ===
lightroom-response = type=http-response, pattern=^https:\/\/photos\.adobe\.io\/v2\/accounts, script-path=https://raw.githubusercontent.com/iSteal-it/script/main/Lightroom.json, requires-body=true, timeout=10, max-size=131072

# === PHOTOSHOP EXPRESS PREMIUM - iSteal-it ===
photoshop-response = type=http-response, pattern=^https:\/\/lcs-mobile-cops\.adobe\.io\/mobile_profile, script-path=https://raw.githubusercontent.com/iSteal-it/script/main/Photoshop.json, requires-body=true, timeout=10, max-size=131072

# === EMBY PREMIERE - chavyleung ===
emby-response = type=http-response, pattern=^https?://mb3admin\.com/admin/service/registration/validateDevice, script-path=https://raw.githubusercontent.com/chavyleung/scripts/master/emby/emby.js, requires-body=true, timeout=10

# === KINEMASTER PRO - z3rokaze (2026-04-21) ===
kinemaster-response = type=http-response, pattern=^https://api-account\.kinemasters\.com/v\d/user/subscribe$, script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/Kinemaster.js, requires-body=true, timeout=10

# === CALM PREMIUM - iSteal-it ===
calm-response = type=http-response, pattern=^https:\/\/api\.calm\.com\/me$, script-path=https://raw.githubusercontent.com/iSteal-it/script/main/calm.json, requires-body=true, timeout=10, max-size=131072

# === HEADSPACE PREMIUM - iSteal-it ===
headspace-response = type=http-response, pattern=^https:\/\/api\.prod\.headspace\.com\/.*\/user-subscriptions, script-path=https://raw.githubusercontent.com/iSteal-it/script/main/headspace.json, requires-body=true, timeout=10, max-size=131072

# === ALIGHT MOTION PRO - z3rokaze (2026-04-21) ===
alightmotion-response = type=http-response, pattern=^https://us-central1-alight-creative\.cloudfunctions\.net/getAccountStatusAndLicenses, script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/AlightMotion.js, requires-body=true, timeout=10

# === WINK VIP - z3rokaze (2026-04-21) ===
wink-response = type=http-response, pattern=^https?://api-sub\.meitu\.com/v2/user/vip_info_by_group\.json, script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/WinkVipCrack.js, requires-body=true, timeout=10

# === TRUECALLER PREMIUM - z3rokaze (2026-04-21) ===
truecaller-response = type=http-response, pattern=^https:\/\/premium-(.+)\.truecaller\.com\/v\d\/(subscriptions|products\/apple), script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/TrueCaller.js, requires-body=true, timeout=10

# === CAMSCANNER PREMIUM - z3rokaze (2026-04-21) ===
camscanner-response = type=http-response, pattern=^https:\/\/(api|api-cs.*)\.intsig\.net\/(purchase\/cs\/query_prop|queryProperty|getPrivilegeItem), script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/camScanner.js, requires-body=true, timeout=15

# === BEAUTYPLUS PREMIUM - z3rokaze (2026-04-21) ===
beautyplus-response = type=http-response, pattern=^https:\/\/(api\.mr\.pixocial\.com\/v1\/manual_unlock|newbeee-api\.beautyplus\.com\/api\/v1\/asset\/balance), script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/BeautyPlus.js, requires-body=true, timeout=60, max-size=0

# === REVENUECAT MULTI-APP (Locket Gold + 车票票) - z3rokaze (2026-04-21) ===
revenuecat-response = type=http-response, pattern=^https:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^\/]+$), script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/revenuecat_multi.js, requires-body=true, timeout=60, max-size=131072
revenuecat-header = type=http-request, pattern=^https:\/\/api\.revenuecat\.com\/.+\/(receipts|subscribers), script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/deleteHeader.js, timeout=60

# === SUB-STORE (Node Management) ===
sub-store-core = type=http-request, pattern=^https?:\/\/sub\.store\/((download)|api\/(preview|sync|(utils\/node-info))), script-path=https://github.com/sub-store-org/Sub-Store/releases/latest/download/sub-store-1.min.js, requires-body=true, timeout=120
sub-store-simple = type=http-request, pattern=^https?:\/\/sub\.store, script-path=https://github.com/sub-store-org/Sub-Store/releases/latest/download/sub-store-0.min.js, requires-body=true, timeout=10
