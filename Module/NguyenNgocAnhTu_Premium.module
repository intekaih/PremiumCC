[Rule]
# === BLOCK QUIC FOR YOUTUBE MITM ===
AND,((DOMAIN-SUFFIX,googlevideo.com), (PROTOCOL,UDP)),REJECT
AND,((DOMAIN,youtubei.googleapis.com), (PROTOCOL,UDP)),REJECT

# === SPOTIFY ADS ===
DOMAIN-SUFFIX,audio-ak-spotify-com.akamaized.net,REJECT
DOMAIN-SUFFIX,audio4-ak-spotify-com.akamaized.net,REJECT
DOMAIN-SUFFIX,heads-ak-spotify-com.akamaized.net,REJECT
DOMAIN-SUFFIX,heads4-ak-spotify-com.akamaized.net,REJECT
DOMAIN,spclient.wg.spotify.com,DIRECT
DOMAIN-KEYWORD,spotify-ads,REJECT

# === YOUTUBE AD DOMAINS - COMPREHENSIVE BLOCKING ===
# Ad Networks & Analytics
DOMAIN-SUFFIX,doubleclick.net,REJECT
DOMAIN-SUFFIX,googleadservices.com,REJECT
DOMAIN-SUFFIX,googlesyndication.com,REJECT
DOMAIN-SUFFIX,googletagmanager.com,REJECT
DOMAIN-SUFFIX,google-analytics.com,REJECT
# YouTube-specific ad endpoints
DOMAIN,pagead2.googlesyndication.com,REJECT
DOMAIN,www.googleadservices.com,REJECT
DOMAIN,ade.googlesyndication.com,REJECT
DOMAIN,ads.youtube.com,REJECT
DOMAIN,static.doubleclick.net,REJECT
DOMAIN,manifest.googlevideo.com,REJECT
# Additional ad/tracking services
DOMAIN-SUFFIX,gstatic.com,REJECT
DOMAIN-SUFFIX,googleusercontent.com,REJECT
DOMAIN-SUFFIX,googleadmob.com,REJECT
DOMAIN-KEYWORD,ad.youtube,REJECT
DOMAIN-KEYWORD,ads,REJECT
# YouTube content (DIRECT to avoid blocking)
DOMAIN,www.youtube.com,DIRECT
DOMAIN,m.youtube.com,DIRECT
DOMAIN,youtubei.googleapis.com,DIRECT
DOMAIN-SUFFIX,ytimg.com,DIRECT
DOMAIN-SUFFIX,yt.be,DIRECT

[URL Rewrite]
# === YOUTUBE AD BLOCK - COMPREHENSIVE ===
# Block all ad/stats endpoints
^https?:\/\/(www|s|m)\.youtube\.com\/api\/stats(\/|\?) - reject-200
^https?:\/\/(www|s)\.youtube\.com\/(pagead|ptracking|api\/resource) - reject-200
^https?:\/\/(www|m)\.youtube\.com\/(get_|generate_).*204 - reject-200
^https?:\/\/(www|m)\.youtube\.com\/(logging|get_watch|get_midroll|api\/ads) - reject-200
# Block analytics and tracking
^https?:\/\/(www|s)\.youtube\.com\/api\/.*/(browse|next|player).*&has_guide - reject-200
^https?:\/\/(www|s)\.youtube\.com\/youtubei\/v1.*/(log_event|get_|search_suggestions) - reject-200
# Block player ad/ctier parameters  
^https?:\/\/s\.youtube\.com\/api\/stats\/qoe\?.* - reject-200
^https?:\/\/www\.youtube\.com\/api\/stats\/qoe\?.* - reject-200
^https?:\/\/www\.youtube\.com\/api\/resource\? - reject-200
# Block googlevideo ad requests
^https?:\/\/[\w-]+\.googlevideo\.com\/(?!(dclk_video_ads|videoplayback\?)).+&oad - reject-200
^https?:\/\/[\w-]+\.googlevideo\.com\/(ptracking|pagead|initplayback.*&oad) - reject-200
^https?:\/\/[\w-]+\.googlevideo\.com\/\.+\.m3u8.*(ads|oad) - reject-200
# Block youtubei ad endpoints
^https?:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/(browse|next|player|get_watch|search|guide).*adformat - reject-200
^https?:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/log_event - reject-200
^https?:\/\/youtubei\.googleapis\.com\/.*?\?.*&ctier= - reject-200

# === YOUTUBE CTIER BYPASS & PARAMETER REWRITE ===
(^https?:\/\/[\w-]+\.googlevideo\.com\/(?!dclk_video_ads).+?)&ctier=L(&.+) $1$2 302
(^https?:\/\/[\w-]+\.googlevideo\.com\/(?!dclk_video_ads).+?)&rn=(&.+) $1$2 302
(^https?:\/\/[\w-]+\.googlevideo\.com\/(?!dclk_video_ads).+?)&range=(&.+) $1$2 302
(^https?:\/\/[\w-]+\.googlevideo\.com\/.+?)&sq=(&.+) $1$2 302

# === REVENUECAT REMOVE ETAG ===
^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^\/]+$) header-remove X-RevenueCat-ETag 302
^https?:\/\/api\.revenuecat\.com\/.+\/(receipts$|subscribers\/[^\/]+$) header-remove x-revenuecat-etag 302

# === SPOTIFY REMOVE CACHE HEADERS ===
^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(user-customization-service\/v1\/customize|bootstrap\/v1\/bootstrap)$ header-remove if-none-match 302

[MITM]
enable = true
hostname = *.googlevideo.com, manifest.googlevideo.com, *.youtube.com, *.ytimg.com, s.youtube.com, youtubei.googleapis.com, *.google-analytics.com, *.googleadservices.com, *.googlesyndication.com, *.doubleclick.net, *.gstatic.com, spclient.wg.spotify.com, *-spclient.spotify.com, api.revenuecat.com, api.picsart.c*, api.meiease.c*, api-mobile.soundcloud.com, mb3admin.com, api-account.kinemasters.com, photos.adobe.io, lcs-mobile-cops.adobe.io, api.calm.com, api.prod.headspace.com, us-central1-alight-creative.cloudfunctions.net, api-sub.meitu.com, premium*.truecaller.com, ap*.intsig.net, api.mr.pixocial.com, newbeee-api.beautyplus.com, sub.store

[Script]
# === YOUTUBE PREMIUM - DivineEngine (đã test ok 2026-05) ===
# Matches ALL YouTube API v1 endpoints to remove ads from initial load
youtube.response = type=http-response, pattern=^https://youtubei\.googleapis\.com/youtubei/v1\/(browse|next|player|search|reel|guide|account|get_watch|channel|startup|home|feed|search_suggestions|get_|notification|explore)(\?(.*))?$, script-path=https://raw.githubusercontent.com/DivineEngine/Profiles/master/Quantumult/Rewrite/Block/YouTubeAds.js, requires-body=true, timeout=30, max-size=131072

# === SPOTIFY PREMIUM - app2smile (Updated 2025.06.20) ===
spotify-json = type=http-request, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(artistview\/v1\/artist|album-entity-view\/v2\/album)\/, script-path=https://raw.githubusercontent.com/app2smile/rules/master/js/spotify-json.js, requires-body=false, timeout=10, max-size=131072
spotify-proto = type=http-response, pattern=^https:\/\/(spclient\.wg\.spotify\.com|.*-spclient\.spotify\.com(:443)?)\/(bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$, script-path=https://raw.githubusercontent.com/app2smile/rules/master/js/spotify-proto.js, requires-body=true, timeout=10, max-size=131072

# === SOUNDCLOUD GO+ - z3rokaze (2026-04-21) ===
soundcloud-response = type=http-response, pattern=^https://api-mobile\.soundcloud\.com/configuration/ios$, script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/SoundCloudGoPlus.js, requires-body=true, timeout=15

# === PICSART GOLD - NobyDa (2025) ===
picsart-response = type=http-response, pattern=^https://api\.(picsart|meiease)\.c(n|om)\/shop/subscription\/(validate|apple\/purchases), script-path=https://raw.githubusercontent.com/NobyDa/Script/master/Surge/JS/PicsArt.js, requires-body=true, max-size=0, timeout=30

# === LIGHTROOM PREMIUM - iSteal-it ===
lightroom-response = type=http-response, pattern=^https:\/\/photos\.adobe\.io\/v2\/accounts, script-path=https://raw.githubusercontent.com/iSteal-it/script/main/Lightroom.json, requires-body=true, timeout=10, max-size=131072

# === PHOTOSHOP EXPRESS PREMIUM - iSteal-it ===
photoshop-response = type=http-response, pattern=^https:\/\/lcs-mobile-cops\.adobe\.io\/mobile_profile, script-path=https://raw.githubusercontent.com/iSteal-it/script/main/Photoshop.json, requires-body=true, timeout=10, max-size=131072

# === EMBY PREMIERE - chavyleung ===
emby-response = type=http-response, pattern=^https?://mb3admin\.com/admin/service/registration/validateDevice, script-path=https://raw.githubusercontent.com/chavyleung/scripts/master/emby/emby.js, requires-body=true, timeout=10

# === KINEMASTER PRO - z3rokaze (2026-04-21) ===
kinemaster-response = type=http-response, pattern=^https://api-account\.kinemasters\.com/v\d/user/subscribe$, script-path=https://raw.githubusercontent.com/z3rokaze/NguyenNgocAnhTu/main/Module/js/Kinemaster.js, requires-body=true, timeout=10

