# ═══════════════════════════════════════
# 🔐 RevenueCat Multi-App - PremiumCC (v5.2)
# Locket Gold + 车票票 VIP
# ═══════════════════════════════════════
http-response ^https:\/\/api\.revenuecat\.com\/.*\/(receipts$|subscribers\/[^/]+$) script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/revenuecat_multi.js,requires-body=true,timeout=15,tag=RC-Multi
http-request ^https:\/\/api\.revenuecat\.com\/.*\/(receipts|subscribers) script-path=https://raw.githubusercontent.com/intekaih/PremiumCC/main/Module/js/deleteHeader.js,timeout=5,tag=RC-Hdr

[MITM]
hostname=-redirector*.googlevideo.com,*.googlevideo.com,www.youtube.com,s.youtube.com,youtubei.googleapis.com,spclient.wg.spotify.com,*-spclient.spotify.com,api.revenuecat.com,api.picsart.c*,api.meiease.c*,api-mobile.soundcloud.com,mb3admin.com,api-account.kinemasters.com,photos.adobe.io,lcs-mobile-cops.adobe.io,app.algoriddim.com,api.calm.com,api.busuu.com,api.prod.headspace.com,vsco.co,api.mojo-app.com,widgetsmith.com,api.funimate.com,api.reface.video,api.unfold.app,us-central1-alight-creative.cloudfunctions.net,api-sub.meitu.com,premium*.truecaller.com,ap*.intsig.net,api.mr.pixocial.com,newbeee-api.beautyplus.com,sub.store
